# DevOps Lab Inventory - All Servers

[all:vars]
ansible_user=ansible
ansible_password=password
ansible_become_password=password
ansible_ssh_common_args='-o StrictHostKeyChecking=no'
ansible_python_interpreter=/usr/bin/python3

# DNS Servers
[dns]
prdx-dns101 ansible_host=10.31.3.11

# Database Servers
[database]
prdx-db101 ansible_host=10.31.3.12

# Web Servers
[webservers]
prdx-webserver101 ansible_host=10.31.3.21
prdx-webserver102 ansible_host=10.31.3.22
prdx-webserver103 ansible_host=10.31.3.23

# Load Balancer
[loadbalancer]
prdx-haproxy101 ansible_host=10.31.3.30

# Monitoring
[monitoring]
prdx-nagios101 ansible_host=10.31.3.40

# Ansible Server
[ansible]
prdx-ansible101 ansible_host=10.31.3.10

# Docker
[docker]
prdx-dprimary101 ansible_host=10.31.3.50

# Kubernetes
[kubernetes]
prdx-kube101 ansible_host=10.31.3.60

# All Linux Servers
[linux:children]
dns
database
webservers
loadbalancer
monitoring
ansible
docker
kubernetes

# Web Tier
[web:children]
webservers
loadbalancer

# App Tier
[app:children]
webservers
database
docker
kubernetes
